{
  "name": "ai-workflow-playground",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "run-s build:*",
    "build:browser": "vite build",
    "demo": "run-s demo:*",
    "demo:cli": "tsx demos/cli/main.ts",
    "dev": "run-p dev:* --print-label",
    "dev:browser": "vite",
    "preview": "run-s preview:*",
    "preview:browser": "vite preview",
    "test": "run-s test:*",
    "test:browser": "playwright test",
    "pretest:browser": "npm run build:browser",
    "test:kernel-purity": "tsx scripts/check-kernel-purity.ts",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run",
    "watch": "vitest",
    "sandcastle": "npx sandcastle docker build-image && tsx .sandcastle/main.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jamerrone/ai-workflow-playground.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Jamerrone/ai-workflow-playground/issues"
  },
  "homepage": "https://github.com/Jamerrone/ai-workflow-playground#readme",
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.10",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^3.2.4"
  }
}
